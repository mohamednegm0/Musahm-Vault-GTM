{
  "name": "musahm-vault-monorepo",
  "version": "0.1.0",
  "description": "Musahm Vault prototype monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@musahm/web",
    "dev:mobile": "npm run dev --workspace=@musahm/mobile",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "type-check": "npm run type-check --workspaces"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.13.2"
  }
}
